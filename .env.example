# LLM Provider: 'ollama', 'groq', 'huggingface', 'gemini', 'openai'
LLM_PROVIDER=ollama
LLM_MODEL=llama3

# Embedding Provider: 'local', 'openai', 'gemini'
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Reranker Model
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# In-memory or local ChromaDB path
CHROMA_DB_PATH=data/embeddings

# API Keys (Provide based on your LLM_PROVIDER / EMBEDDING_PROVIDER)
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
HF_API_KEY=

# LangSmith Monitoring (Optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=compliance-copilot

# Backend Security
API_BEARER_TOKEN=compliance_secret_token_123

# App Settings
BACKEND_URL=http://localhost:8000
PORT=8000
HOST=127.0.0.1
